# Application Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGO_URL=mongodb://localhost:27017/yellowdodle

# Authentication Configuration
JWT_SECRET=your_jwt_secret_key_here_must_be_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# Carrier Mode Configuration
# Set to 'true' to allow simulated mock mode when actual API credentials are not provided.
MOCK_CARRIERS=true

# FedEx API configuration (sandbox URLs are defaulted if omitted)
FEDEX_API_URL=https://apis-sandbox.fedex.com
FEDEX_CLIENT_ID=your_fedex_client_id
FEDEX_CLIENT_SECRET=your_fedex_client_secret
FEDEX_ACCOUNT_NUMBER=your_fedex_account_number

# Canada Post API configuration
CANADA_POST_API_URL=https://ct.soa-gw.canadapost.ca
CANADA_POST_USERNAME=your_username
CANADA_POST_PASSWORD=your_password
CANADA_POST_CUSTOMER_NUMBER=your_customer_number

# Shipmozo API configuration
SHIPMOZO_API_URL=https://shipping-api.com/app/api/v1
SHIPMOZO_PUBLIC_KEY=your_public_key
SHIPMOZO_PRIVATE_KEY=your_private_key


# razopray configuration

RAZORPAY_TEST_KEY=my_test_key
RAZORPAY_TEST_SECRET=my_test_secret
RAZORPAY_LIVE_KEY=your_production_key_id
RAZORPAY_LIVE_SECRET=your_production_key_secret

# Tax Configuration
TAX_RATE=0.18

# UPS Credentials
UPS_API_URL=https://wwwcie.ups.com
UPS_CLIENT_ID=your_ups_client_id
UPS_CLIENT_SECRET=your_ups_client_secret
UPS_ACCOUNT_NUMBER=your_ups_account_number
